# =====================================================================
# .env.example — copia este archivo a .env y rellena los valores reales.
# .env NO se commitea (está en .gitignore).
# =====================================================================

# Payload — secret para firmar tokens de auth. 32+ chars aleatorios.
# Generar: openssl rand -hex 32
PAYLOAD_SECRET=

# Postgres — connection string del entorno.
# Local con Docker: postgresql://postgres:postgres@127.0.0.1:5432/caracol_next_ditu
# Neon / Vercel Marketplace: pegar la URL que entregue el proveedor.
DATABASE_URI=

# URL pública del frontend (sin slash final).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL del servidor Payload (admin + API). Normalmente igual al frontend en monolito Next.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ===== (Fase 5) Integraciones — dejar vacías hasta que se conecten =====

# Resend (formulario de contacto)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Vercel AI Gateway (IA de recomendación)
AI_GATEWAY_API_KEY=

# APIs de audiencia/redes (TBD — definir fuente con cliente)
AUDIENCE_API_URL=
NETWORKS_API_URL=
